<!-- views/index.ejs -->
<!DOCTYPE html>
<html>

<head>
  <title><%= title %></title>
</head>

<body>
  <h1><%= title %></h1>
  <form action="/search" method="get">
    <label for="search">Search: </label>
    <input type="text" name="search" id="search" value="<%= locals.search %>" required />
    <button type="submit">Search</button>
  </form>
  <ul>
    <% if (locals.users && Object.keys(locals.users).length > 0) {%>
    <% users.forEach(user => { %>
    <li>
      ID: <%= user.id %>, Name: <%= user.firstName %> <%= user.lastName %>, Email: <%= user.email %>, Age: <%= user.age %>, Bio <%= user.bio %>
      <a href="/<%= user.id %>/update">Update</a>
      <form action="/<%= user.id %>/delete" method="POST" style="display:inline;">
        <button type="submit" onclick="return confirm('Are you sure you want to delete this user?')">Delete</button>
      </form>
    </li>
    <% }); %>
    <% } else if (locals.search) {%>
    <p>No such name found</p>
    <% } %>
  </ul>
  <% if (locals.search) { %>
  <a href="/">Clear Search</a>
  <% } %>
  <a href="/create">Create a user</a>

</body>

</html>