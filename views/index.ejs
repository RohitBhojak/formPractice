<!DOCTYPE html>
<html lang="en">
<%- include("partials/head.ejs") %>
<body>
  <div class="app-container">
    <header class="top-app-bar">
      <h1><%= typeof title !== 'undefined' ? title : 'Users' %></h1>
    </header>
    
    <main class="content">
      <div class="card card-search">
        <form action="/search" method="get" class="search-form">
          <div class="input-field search-input" style="flex: 1;">
            <input type="text" name="search" id="search" value="<%= locals.search || '' %>" required placeholder=" " />
            <label for="search">Search users</label>
          </div>
          <button type="submit" class="btn btn-filled">Search</button>
          <% if (locals.search) { %>
            <a href="/" class="btn btn-tonal">Clear</a>
          <% } %>
        </form>
      </div>

      <div class="card">
        <% if (locals.users && Object.keys(locals.users).length > 0) { %>
          <ul class="user-list">
            <% users.forEach(user => { %>
              <li class="user-item">
                <div class="user-info">
                  <span class="user-name"><%= user.firstName %> <%= user.lastName %></span>
                  <span class="user-id">Email: <%= user.email %> • Age: <%= user.age %></span>
                  <% if (user.bio) { %>
                    <span class="user-bio"><%= user.bio %></span>
                  <% } %>
                </div>
                <div class="user-actions">
                  <a href="/<%= user.id %>/update" class="btn btn-tonal">Edit</a>
                  <form action="/<%= user.id %>/delete" method="POST" class="inline-form">
                    <button type="submit" class="btn btn-alert" onclick="return confirm('Delete this user?')">Delete</button>
                  </form>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } else if (locals.search) { %>
          <div class="empty-state">
            <p>No such name found</p>
          </div>
        <% } else { %>
          <div class="empty-state">
            <p>No users found.</p>
          </div>
        <% } %>
      </div>

      <div class="fab-container">
        <a href="/create" class="fab">
          <svg viewBox="0 0 24 24"><path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
          <span class="fab-label">Create User</span>
        </a>
      </div>
    </main>
  </div>
</body>
</html>